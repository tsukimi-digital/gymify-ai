{
  "version": 2,
  "builds": [
    {
      "src": "packages/backend/src/vercel.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["packages/shared/dist/**"],
        "maxDuration": 300
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/backend/src/vercel.ts"
    }
  ]
}
