{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build -w packages/shared && npm run build -w packages/backend",
  "functions": {
    "packages/backend/src/vercel.ts": {
      "includeFiles": "packages/shared/dist/**,packages/backend/node_modules/.prisma/**"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "packages/backend/src/vercel.ts"
    }
  ]
}
