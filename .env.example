# ─────────────────────────────────────────────────────────────────────────────
# Gymify AI — Environment Variables
# Copy to .env and fill in values before starting.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://gymify:gymify_dev@localhost:5432/gymify_dev"

# JWT
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_REFRESH_SECRET="another-long-random-string-for-refresh-tokens"

# Anthropic / Claude
ANTHROPIC_API_KEY="sk-ant-..."

# Server
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Worker
WORKER_CONCURRENCY=2

# Feature flags
MOCK_ANTHROPIC=false          # Set to true in E2E tests to skip real Claude calls

# Sentry (optional, leave blank in dev)
SENTRY_DSN=""
